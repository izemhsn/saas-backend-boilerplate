{
  "name": "saas-backend-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready Express 5 + Prisma SaaS backend starter with JWT auth, role-based access, request validation, rate limiting, and a full test suite.",
  "main": "src/server.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "worker:dev": "nodemon src/worker.js",
    "worker:start": "node src/worker.js",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izemhsn/saas-backend-boilerplate.git"
  },
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "jwt",
    "authentication",
    "saas",
    "boilerplate",
    "backend"
  ],
  "author": "izemhsn",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/izemhsn/saas-backend-boilerplate/issues"
  },
  "homepage": "https://github.com/izemhsn/saas-backend-boilerplate#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.67.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.9",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "resend": "^6.17.1",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
