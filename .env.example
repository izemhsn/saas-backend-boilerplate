PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# Reverse proxy hops to trust for req.ip / rate limiting (e.g. 1 behind one proxy).
# Leave unset for local/direct connections. Accepts a number or an Express trust-proxy value.
# TRUST_PROXY=1

# Database (must match docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas-boilerplate_db"

# JWT — MUST be unique, random, and at least 32 chars in production (enforced at boot).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# Email (Resend) — get your API key at https://resend.com/api-keys
RESEND_API_KEY=""
FROM_EMAIL="noreply@yourdomain.com"
APP_URL="http://localhost:3000"

# Stripe — get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""